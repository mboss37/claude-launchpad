{
  "name": "claude-launchpad",
  "version": "1.17.1",
  "description": "Score your Claude Code config, fix the gaps with hooks and permissions, prove Claude follows your rules with eval. Includes persistent memory for Claude Code with free cross-machine sync (GitHub Gist), ranked context injection, and benchmarks that measure whether memory actually helps.",
  "type": "module",
  "bin": {
    "claude-launchpad": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsup",
    "start": "tsx src/cli.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "publish:dev": "npm version prerelease --preid=dev --no-git-tag-version && node scripts/sync-version.mjs && npm publish --tag dev",
    "publish:release": "pnpm build && node scripts/verify-dist-version.mjs && npm publish",
    "docs:dev": "cd docs && pnpm dev",
    "docs:build": "cd docs && pnpm build",
    "bench:memory": "vitest run --config vitest.bench.config.ts --reporter=verbose",
    "test:regression": "pnpm build && bash tests/regression/doctor-regression.sh"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "llm",
    "ai-tools",
    "developer-tools",
    "cli",
    "config",
    "linter",
    "scaffold",
    "hooks",
    "eval",
    "diagnostics",
    "memory",
    "persistent-memory",
    "mcp",
    "model-context-protocol",
    "agentic",
    "code-quality",
    "claude-code-memory",
    "cross-machine-sync",
    "memory-sync",
    "context-injection",
    "claude-md",
    "verification",
    "ai-memory",
    "knowledge-base"
  ],
  "author": "mboss37",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mboss37/claude-launchpad.git"
  },
  "bugs": {
    "url": "https://github.com/mboss37/claude-launchpad/issues"
  },
  "homepage": "https://mboss37.github.io/claude-launchpad/",
  "files": [
    "dist/",
    "scenarios/"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.26.1",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "shell-quote": "^1.8.4",
    "yaml": "^2.8.3"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/shell-quote": "^1.7.5",
    "better-sqlite3": "^11.10.0",
    "ink-testing-library": "^4.0.0",
    "sqlite-vec": "0.1.9",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "fast-uri": ">=3.1.2",
      "hono": ">=4.12.25",
      "@hono/node-server": ">=1.19.13",
      "ws": ">=8.21.0",
      "vite": ">=8.0.16",
      "ip-address": ">=10.1.1",
      "postcss": ">=8.5.10",
      "qs": ">=6.15.2",
      "esbuild": ">=0.28.1"
    }
  }
}
