{
  "name": "claude-launchpad",
  "version": "0.8.3",
  "description": "CLI toolkit that makes Claude Code setups measurably good - scaffold, diagnose, evaluate, remember",
  "type": "module",
  "bin": {
    "claude-launchpad": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsup",
    "start": "tsx src/cli.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "publish:dev": "npm version prerelease --preid=dev --no-git-tag-version && node scripts/sync-version.mjs && npm publish --tag dev",
    "publish:release": "npm publish",
    "docs:dev": "cd docs && pnpm dev",
    "docs:build": "cd docs && pnpm build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "developer-tools",
    "cli",
    "config",
    "diagnostics",
    "memory",
    "persistent-memory",
    "mcp"
  ],
  "author": "mboss37",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mboss37/claude-launchpad.git"
  },
  "homepage": "https://mboss37.github.io/claude-launchpad/",
  "files": [
    "dist/",
    "scenarios/"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.26.1",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "yaml": "^2.8.3"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "blessed": "^0.1.81",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "@types/better-sqlite3": "^7.6.12",
    "@types/blessed": "^0.1.25",
    "@types/node": "^25.5.0",
    "better-sqlite3": "^11.10.0",
    "sqlite-vec": "^0.1.9",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
