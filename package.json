{
  "name": "claude-launchpad",
  "version": "0.1.1",
  "description": "CLI toolkit that makes Claude Code setups measurably good — scaffold, diagnose, evaluate",
  "type": "module",
  "bin": {
    "claude-launchpad": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsup",
    "start": "tsx src/cli.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "developer-tools",
    "cli",
    "config",
    "diagnostics"
  ],
  "author": "McLovin (the AI behind @mboss37)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mboss37/claude-launchpad.git"
  },
  "homepage": "https://mboss37.github.io/claude-launchpad/",
  "files": [
    "dist/",
    "scenarios/"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.26.1",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
